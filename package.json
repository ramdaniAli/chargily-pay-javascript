{
  "name": "@dalli/chargily-pay",
  "version": "3.1.0",
  "description": "JavaScript Library for Chargily Pay™ Gateway - V2. The easiest and free way to integrate e-payment API through EDAHABIA of Algerie Poste and CIB of SATIM into your JS project.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "nodemon --exec ts-node ./src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramdaniAli/chargily-pay-javascript.git"
  },
  "keywords": [
    "chargily",
    "payment",
    "gateway",
    "e-payment",
    "algeria",
    "edahabia",
    "cib",
    "javascript",
    "typescript"
  ],
  "author": {
    "name": "Abderraouf Zine",
    "email": "rofazayn@gmail.com",
    "url": "https://github.com/rofazayn"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ramdaniAli/chargily-pay-javascript/issues"
  },
  "homepage": "https://github.com/ramdaniAli/chargily-pay-javascript#readme",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5",
    "vitest": "^4.0.18"
  }
}
